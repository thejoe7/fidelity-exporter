FIDELITY_USERNAME=your@email.com
FIDELITY_PASSWORD=yourpassword

# Optional: set to 1 to print stack traces and save screenshots on errors.
DEBUG=0

# Optional: use installed Chrome and a specific persistent Chrome profile.
# For macOS Chrome's default profile:
# FIDELITY_BROWSER_CHANNEL=chrome
# FIDELITY_USER_DATA_DIR=~/Library/Application Support/Google/Chrome
# FIDELITY_PROFILE_DIRECTORY=Default
